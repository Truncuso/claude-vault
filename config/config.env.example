# claude-vault — vault-local configuration
# Copy this file to config/config.env and edit for your vault.
# config/config.env is gitignored — never commit it.

# --- QMD ---
export QMD_DAEMON_PORT=8181

# --- Ollama ---
export OLLAMA_BASE_URL="http://127.0.0.1:11434"

# --- Obsidian app vault name (for CLI) ---
export OBSIDIAN_VAULT_NAME="Obsidian_Test_Vault"
